# TX Public Safety — Environment Configuration
# Copy to .env and customize as needed.
# The defaults work out-of-the-box for Mac + Ollama.

# ─── LLM Backend ────────────────────────────────────────────
# Local Ollama (default for Mac development)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=qwen2.5:14b

# ─── To use vLLM on GPU server, change to: ──────────────────
# LLM_BASE_URL=http://your-gpu-server:8001/v1
# LLM_MODEL=Qwen/Qwen3-32B

# ─── Server ─────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8006

# ─── Agent Intervals (seconds) ──────────────────────────────
NEWS_INTERVAL=120
GOV_INTERVAL=180
SOCIAL_INTERVAL=90
WEATHER_INTERVAL=300
CLASSIFIER_INTERVAL=300
TREND_INTERVAL=120
REPORT_INTERVAL=3600

# ─── Database ───────────────────────────────────────────────
# SQLite for local, Postgres for production
# DB_URL=postgresql://user:pass@localhost/txsafety
